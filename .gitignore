# ══════════════════════════════════════════════════════════════════
#  Dinamica Budget — .gitignore
# ══════════════════════════════════════════════════════════════════

# ─── Environment / Secrets ────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local
!.env.example

# ─── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# ─── Virtual Environments ────────────────────────────────────────
.venv/
venv/
env/
pytest_cache/

# ─── ML Model Cache (large binaries ~500MB) ──────────────────────
ml_models/

# ─── Testing ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
junit.xml
test-results/

# ─── Node.js / Frontend ──────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env.production
*.tsbuildinfo

# ─── Logs ────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── IDE / Editor ────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-*

# ─── OS ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── Docker ──────────────────────────────────────────────────────
docker-compose.override.yml

# ─── Deploy Artifacts ────────────────────────────────────────────
output/
ETAPA
*.bak
*.tmp

# ─── Playwright / Browser Tests ──────────────────────────────────
.playwright-cli/
output/playwright/
test-results/
playwright-report/

# ─── Database Backups (keep out of git) ──────────────────────────
*.sql
*.dump
*.pgdump
!alembic/versions/*.py

# ─── NSSM / Installers (downloaded at deploy time) ──────────────
*.msi
*.exe
!deploy-dinamica.bat
!remove-dinamica.bat

logs
tabelas
reseultado
resultado/

# ─── AGENTS ──────────────
.opencode/
.kilo/
.kimi/
.kiro/
.claude/
.amazonq/
.agents/*
!.agents/skills/
.agents/skills/*
!.agents/skills/context7-mcp/
!.agents/skills/context7-mcp/**
!.agents/skills/project-pipeline/
!.agents/skills/project-pipeline/SKILL.md
.agents/skills/project-pipeline/references/
.agents/skills/project-pipeline/templates/
!.agents/skills/semantic-memory/
!.agents/skills/semantic-memory/**
.agents/skills/semantic-memory/AGENTS.md
.codex
